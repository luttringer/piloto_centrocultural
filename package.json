{
  "name": "tw-postcss-base",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "watch:css": "postcss src/styles.css -o dist/styles.css --watch",
    "build:css": "NODE_ENV=production postcss src/styles.css -o dist/styles.min.css",
    "min:js": "terser src/scripts/*.js -o dist/scripts.min.js -c -m",
    "build": "npm run build:css && npm run min:js"
  },
